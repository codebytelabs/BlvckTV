# TMDB v3 API key — required for full movie/TV catalog (free at https://www.themoviedb.org/settings/api)
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Optional: DLHD protected API key for channel logos (contact livetvon@protonmail.com)
# Without this, Live TV loads ~900 channels via HTML scrape fallback
VITE_DLHD_API_KEY=
